# ScreenSense AI — Environment Config
# Copy to .env and fill in your values

# ── ntfy.sh push topic ───────────────────────────────────────────────────────
# Pick ANY unique string. You'll subscribe to this in the ntfy phone app.
# Example: screensense-john-2025  (make it hard to guess = private)
NTFY_TOPIC=screensense-ai-alerts

# ── Server IP ────────────────────────────────────────────────────────────────
# Auto-detected from your LAN. Override if wrong.
# Find it: run `ipconfig` (Windows) or `ifconfig` (Mac/Linux)
# SERVER_IP=192.168.1.100

# ── Firebase (optional) ──────────────────────────────────────────────────────
# Leave blank to skip Firestore. Put serviceAccountKey.json in project folder.
# Or paste JSON string here:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# ── Port ─────────────────────────────────────────────────────────────────────
PORT=5000
